# sessions/trade.env — 핵심 트레이딩 파라미터
# 이 파일을 trade.env로 복사 후 값 설정: cp trade.env.example trade.env
# trade.env는 .gitignore에 의해 git 추적 제외됨
# watcher가 매 틱(60초)마다 자동 재읽기 — pm2 restart 불필요

# === Binance 자격증명 ===
# 비어있으면 sessions/binance-api-key.txt, binance-api-secret.txt 사용
BINANCE_API_KEY=
BINANCE_API_SECRET=

# === Bybit 자격증명 ===
# 비어있으면 sessions/bybit-credentials.txt 사용
BYBIT_API_KEY=
BYBIT_API_SECRET=

# === 트레이딩 파라미터 (비어있으면 trader.json 기본값 사용) ===
LEVERAGE=2
MARGIN_USD=10
NOTIONAL_USD=20
